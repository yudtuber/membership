rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == "admin";
    }

    match /members/{uid} {
      allow create: if isOwner(uid);
      allow read, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{id} {
      allow create: if true;
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /leads/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /newsletter/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /supportTickets/{id} {
      allow create: if true;
      allow read, update: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /products/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /payouts/{id} {
      allow read, write: if isAdmin();
    }

    match /supportReplies/{id} {
      allow read, write: if isAdmin();
    }

    match /views/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /clicks/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /sales/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
